# ──────────────────────────────────────────────────────────────
# .env.example — Copy this file to .env and fill in real values.
# Never commit the actual .env file to source control.
# ──────────────────────────────────────────────────────────────

# ── Server ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ────────────────────────────────────────────────────
# Local development:  mongodb://localhost:27017/notification_service
# Docker Compose:     mongodb://mongodb:27017/notification_service
# Atlas:              mongodb+srv://<user>:<pass>@cluster.mongodb.net/notification_service
MONGODB_URI=mongodb://localhost:27017/notification_service
